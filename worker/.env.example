# Shared secret. Must match the Vercel app's EXPORT_WORKER_TOKEN.
EXPORT_WORKER_TOKEN=replace-me

# Keep PDF off until LibreOffice is installed in the worker image.
ENABLE_PDF_EXPORT=0

# Optional runtime tuning
PYTHON_BIN=python
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5

# Optional when PDF export is enabled and soffice is not on PATH.
# SOFFICE_PATH=/usr/bin/soffice
